# الصور
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.svg
*.ico

# الفيديو
*.mp4
*.avi
*.mov
*.wmv
*.flv

# الصوت
*.mp3
*.wav
*.aac
*.ogg

# ============================================
# 13. ملفات الإنتاج (Production Files)
# ============================================

build/
dist/
out/
*.min.js
*.min.css
*.bundle.js
*.bundle.css

# ============================================
# 14. ملفات Supabase (إذا كانت موجودة)
# ============================================

supabase/.branches
supabase/.temp
supabase/seed.sql
supabase/migrations/*

# ============================================
# 15. ملفات أخرى
# ============================================

# Docker
docker-compose.override.yml
docker-compose.dev.yml
*.dockerignore

# ESLint
.eslintcache

# Prettier
.prettiercache

# TypeScript
*.tsbuildinfo

# Coverage
*.lcov
*.coverage

