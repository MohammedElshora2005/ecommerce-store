# ============================================
# .gitignore - ملف استثناءات Git للمشروع
# ============================================

# ============================================
# 1. مجلدات الاعتماديات (Dependencies)
# ============================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 2. مجلدات البناء والتنفيذ (Build & Output)
# ============================================

# Vite / Build
dist/
dist-ssr/
*.local
build/
out/
.vite/
vite.config.js.timestamp-*

# ============================================
# 3. ملفات البيئة (Environment Variables)
# ============================================

# Supabase
.env
.env.local
.env.*.local
.env.production
.env.development

# Vite Environment
.env.vite
.env.vite.local

# ============================================
# 4. ملفات النظام (OS Files)
# ============================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
*~
*.swp
*.swo
*.tmp

# ============================================
# 5. ملفات المحررات (Editor Files)
# ============================================

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.history/
*.vsix

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/
.settings/
.project
.classpath

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.swp
.*.swo

# Emacs
*~
\#*
.\#*

# ============================================
# 6. ملفات الاختبارات (Testing)
# ============================================

# Jest / Testing Library
coverage/
.nyc_output/
*.test.js
*.spec.js
*.test.ts
*.spec.ts
*.test.tsx
*.spec.tsx

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/
cypress/fixtures/

# ============================================
# 7. ملفات السجلات (Logs)
# ============================================

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# 8. ملفات مؤقتة (Temporary Files)
# ============================================

*.cache
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup

# ============================================
# 9. ملفات التحميلات (Downloads)
# ============================================

downloads/
uploads/
temp/
tmp/

# ============================================
# 10. ملفات المستخدمين (User Files)
# ============================================

*.user
*.userosscache
*.sln.docstates

# ============================================
# 11. ملفات التوثيق (Documentation)
# ============================================

*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.xls
*.xlsx

# ============================================
